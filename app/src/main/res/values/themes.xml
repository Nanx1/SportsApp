<resources>
    <style name="Theme.Sports" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hero_bg</item>
        <item name="colorPrimaryVariant">@color/hero_bg</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/hero_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Widget.Sports.Card">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Sports.SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Sports.InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/card_bg</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/card_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Sports.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="backgroundTint">@color/hero_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">18dp</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Sports.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
