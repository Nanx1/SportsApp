<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/hold_progress_bg" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/soft_orange_stroke" />
        </shape>
    </item>
    <item android:id="@+id/hold_progress">
        <clip android:clipOrientation="horizontal" android:gravity="start">
            <shape>
                <solid android:color="@color/hold_progress_orange" />
                <corners android:radius="18dp" />
            </shape>
        </clip>
    </item>
</layer-list>
