<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/dataSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="18dp"
            android:paddingTop="42dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/hero_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/homeNameValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/hero_text"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/home_subtitle_new"
                            android:textColor="@color/hero_subtext"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/homeTotalCheckInValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/hero_text"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_checkin_label"
                                    android:textColor="@color/hero_subtext"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/homeStreakValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/hero_text"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/checkin_streak_label"
                                    android:textColor="@color/hero_subtext"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Sports.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            style="@style/Widget.Sports.SectionTitle"
                            android:text="@string/home_records_title" />

                        <LinearLayout
                            android:id="@+id/recordsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="320dp"
                            android:layout_marginTop="14dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Sports.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            style="@style/Widget.Sports.SectionTitle"
                            android:text="@string/data_calc_title" />

                        <Button
                            android:id="@+id/openBmiToolButton"
                            style="@style/Widget.Sports.SecondaryButton"
                            android:layout_marginTop="14dp"
                            android:text="@string/data_tool_bmi" />

                        <Button
                            android:id="@+id/openCalorieToolButton"
                            style="@style/Widget.Sports.SecondaryButton"
                            android:layout_marginTop="12dp"
                            android:text="@string/data_tool_calorie" />

                        <Button
                            android:id="@+id/openForecastToolButton"
                            style="@style/Widget.Sports.SecondaryButton"
                            android:layout_marginTop="12dp"
                            android:text="@string/data_tool_forecast" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/followSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                style="@style/Widget.Sports.SectionTitle"
                android:text="@string/module_follow_title" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/module_video_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/t25Button"
                style="@style/Widget.Sports.PrimaryButton"
                android:layout_width="240dp"
                android:layout_marginTop="28dp"
                android:text="@string/video_t25" />

            <Button
                android:id="@+id/pamelaButton"
                style="@style/Widget.Sports.PrimaryButton"
                android:layout_width="240dp"
                android:layout_marginTop="12dp"
                android:text="@string/video_pamela" />

            <Button
                android:id="@+id/slimLegButton"
                style="@style/Widget.Sports.PrimaryButton"
                android:layout_width="240dp"
                android:layout_marginTop="12dp"
                android:text="@string/video_slim_leg" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/runSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                style="@style/Widget.Sports.SectionTitle"
                android:text="@string/module_run_title" />

            <TextView
                android:layout_width="290dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/run_tab_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/openOutdoorRunButton"
                style="@style/Widget.Sports.PrimaryButton"
                android:layout_width="240dp"
                android:layout_marginTop="26dp"
                android:text="@string/run_open_outdoor" />

            <Button
                android:id="@+id/openIndoorRunButton"
                style="@style/Widget.Sports.SecondaryButton"
                android:layout_width="240dp"
                android:layout_marginTop="12dp"
                android:text="@string/run_open_indoor" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/profileSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="24dp"
            android:paddingTop="74dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Sports.SectionTitle"
                    android:text="@string/module_profile_title" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/profile_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Sports.InputLayout"
                    android:layout_marginTop="24dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/profile_name_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Sports.InputLayout"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileHeightInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/height_hint"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Sports.InputLayout"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileWeightInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/weight_hint"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/profileBmiValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/profile_bmi_placeholder"
                    android:textColor="@color/accent_green"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/saveProfileButton"
                    style="@style/Widget.Sports.PrimaryButton"
                    android:layout_width="240dp"
                    android:layout_marginTop="18dp"
                    android:text="@string/profile_save" />
            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        app:itemHorizontalTranslationEnabled="false"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
