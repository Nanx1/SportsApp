<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/runModeValue"
        style="@style/Widget.Sports.SectionTitle"
        android:text="@string/module_run_title" />

    <TextView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/run_intro"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/indoorConfigSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/indoorSpeedInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/run_speed_hint"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/indoorInclineInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/run_incline_hint"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="18dp">

            <com.example.sports.RoutePreviewView
                android:id="@+id/routePreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/route_preview_bg" />

            <TextView
                android:id="@+id/indoorPreviewText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/route_preview_bg"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/run_indoor_ready"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/runStatusValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/run_status_idle"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runDistanceValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/runDurationValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/runPositionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/startRunButton"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="18dp"
        android:text="@string/run_start"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:backgroundTint="@color/accent_orange"
        app:cornerRadius="90dp" />

    <FrameLayout
        android:id="@+id/stopRunButton"
        android:layout_width="180dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/stop_button_shell_bg"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/stopRunProgress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/stop_button_progress_bg"
            android:scaleX="0" />

        <TextView
            android:id="@+id/stopRunLabel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/run_stop"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </FrameLayout>

</LinearLayout>
