<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        style="@style/Widget.Sports.SectionTitle"
        android:text="@string/data_tool_calorie" />

    <Spinner
        android:id="@+id/sportTypeSpinner"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/spinner_field_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:spinnerMode="dropdown" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Sports.InputLayout"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/sportWeightInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/weight_hint"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Sports.InputLayout"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/durationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/duration_hint"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/calculateCalorieButton"
        style="@style/Widget.Sports.PrimaryButton"
        android:layout_marginTop="16dp"
        android:text="@string/calculate_calorie" />

    <TextView
        android:id="@+id/calorieResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="@string/calorie_default_result"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

</LinearLayout>
