<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            style="@style/Widget.Sports.SectionTitle"
            android:text="@string/data_tool_forecast" />

        <TextView
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/forecast_intro"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_marginTop="22dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/currentWeightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/forecast_current_weight"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/heightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/height_hint"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/targetWeightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/forecast_target_weight"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Sports.InputLayout"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/intakeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/forecast_intake_hint"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/calculateForecastButton"
            style="@style/Widget.Sports.PrimaryButton"
            android:layout_marginTop="16dp"
            android:text="@string/forecast_calculate" />

        <TextView
            android:id="@+id/forecastResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/forecast_default_result"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
